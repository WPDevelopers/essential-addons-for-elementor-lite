		"lint:css": "stylelint 'src/css/**/*.scss'",
		"lint": "npm run lint:js && npm run lint:css",
		"fix:js": "eslint 'src/js/**/*.js' --fix",
		"fix:css": "stylelint 'src/css/**/*.scss' --fix",
		"fix": "npm run fix:js && npm run fix:css",
		"format": "prettier --write 'src/**/*.{js,scss,css,json}'",
		"format:check": "prettier --check 'src/**/*.{js,scss,css,json}'"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rupok/essential-addons-for-elementor-lite.git"
	},
