{
    "name": "mukul/essential-addons-for-elementor-lite",
    "authors": [
        {
            "name": "Priyo Mukul",
            "email": "17237437+priyomukul@users.noreply.github.com"
        }
    ],
    "repositories": [
        {
            "type": "vcs",
            "url": "https://github.com/priyomukul/wp-notice"
        }
    ],
    "require": {
        "priyomukul/wp-notice": "v2.x-dev"
    },
    "require-dev": {
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0"
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "lint:php": "phpcs --standard=phpcs.xml.dist",
        "fix:php": "phpcbf --standard=phpcs.xml.dist"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
