{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "landingPage": "/wp-admin/post.php?post={{lastCreatedPageID}}&action=elementor",
  "preferredVersions": {
    "wp": "latest",
    "php": "8.2"
  },
  "login": true,
  "steps": [
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "elementor"
      }
    },
    {
      "step": "setSiteOptions",
      "options": {
        "elementor_onboarding_complete": "yes",
        "elementor_friendly_localize": "yes",
        "elementor_hello_theme_migrated": "yes"
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "essential-addons-for-elementor-lite"
      }
    },
    {
      "step": "createPage",
      "pageData": {
        "title": "EA Demo Page",
        "content": "",
        "status": "publish"
      }
    },
    {
      "step": "setPageMeta",
      "pageSelector": { "title": "EA Demo Page" },
      "meta": {
        "_elementor_template_type": "elementor_canvas",
        "_wp_page_template": "elementor_canvas"
      }
    }
  ]
}